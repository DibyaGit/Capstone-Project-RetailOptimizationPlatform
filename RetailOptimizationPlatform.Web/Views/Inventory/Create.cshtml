@model RetailOptimizationPlatform.Core.Entities.Inventory

@{
    ViewData["Title"] = "Add New Inventory";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-plus-circle"></i> Add New Inventory Item</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert" id="validationSummary"></div>

                        <div class="mb-3">
                            <label asp-for="ItemName" class="form-label fw-medium">Item Name <span class="text-danger">*</span></label>
                            <input asp-for="ItemName" class="form-control" placeholder="e.g., Wireless Mouse" />
                            <div asp-validation-for="ItemName" class="invalid-feedback d-block"></div>
                            <small class="text-muted">Maximum 100 characters</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Sku" class="form-label fw-medium">SKU (Stock Keeping Unit) <span class="text-danger">*</span></label>
                            <input asp-for="Sku" class="form-control" placeholder="e.g., MOUSE-001" />
                            <div asp-validation-for="Sku" class="invalid-feedback d-block"></div>
                            <small class="text-muted">Unique identifier, 3-20 characters</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StockQuantity" class="form-label fw-medium">Stock Quantity <span class="text-danger">*</span></label>
                                <input asp-for="StockQuantity" class="form-control" type="number" min="0" placeholder="0" />
                                <div asp-validation-for="StockQuantity" class="invalid-feedback d-block"></div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-medium">Unit Price (₹) <span class="text-danger">*</span></label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                                <div asp-validation-for="Price" class="invalid-feedback d-block"></div>
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Save Item
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}