@model IEnumerable<RetailOptimizationPlatform.Core.Entities.Inventory>

@{
    ViewData["Title"] = "Inventory List";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Inventory Management</h2>
        <a asp-action="Create" class="btn btn-success">Add New Inventory Item</a>
    </div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="searchString" placeholder="Search by item name..." class="form-control" />
                <button type="submit" class="btn btn-primary">Search</button>
                <a asp-action="Index" class="btn btn-secondary">Clear</a>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Item Name</th>
                        <th>SKU</th>
                        <th>Stock Quantity</th>
                        <th>Price</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.ItemName</td>
                            <td>@item.Sku</td>
                            <td>
                                @if (item.StockQuantity < 10)
                                {
                                    <span class="badge bg-danger">@item.StockQuantity (Low)</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@item.StockQuantity</span>
                                }
                            </td>
                            <td>₹@item.Price.ToString("0.00")</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-info btn-sm text-white" onclick="fetchItemDetails(@item.Id)">Quick View</button>

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="quickViewModal" tabindex="-1" aria-labelledby="quickViewModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title" id="quickViewModalLabel">Item Quick View</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2"><strong>Item Name:</strong> <span id="modalName" class="text-muted">Loading...</span></div>
                <div class="mb-2"><strong>SKU:</strong> <span id="modalSku" class="text-muted">Loading...</span></div>
                <div class="mb-2"><strong>Stock Quantity:</strong> <span id="modalStock" class="text-muted">Loading...</span></div>
                <div class="mb-2"><strong>Price:</strong> <span class="text-muted">₹<span id="modalPrice">Loading...</span></span></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function fetchItemDetails(itemId) {
            // 1. Show the popup window immediately
            var myModal = new bootstrap.Modal(document.getElementById('quickViewModal'));
            myModal.show();

            // 2. Set temporary loading text
            document.getElementById('modalName').innerText = "Loading...";
            document.getElementById('modalSku').innerText = "Loading...";
            document.getElementById('modalStock').innerText = "Loading...";
            document.getElementById('modalPrice').innerText = "Loading...";

            // 3. Make the background AJAX request to our new Controller method
            fetch('/Inventory/GetItemDetails/' + itemId)
                .then(response => {
                    if (!response.ok) throw new Error('Network response was not ok');
                    return response.json();
                })
                .then(data => {
                    // 4. Inject the fetched data into the popup window dynamically
                    document.getElementById('modalName').innerText = data.itemName;
                    document.getElementById('modalSku').innerText = data.sku;
                    document.getElementById('modalStock').innerText = data.stockQuantity;
                    document.getElementById('modalPrice').innerText = parseFloat(data.price).toFixed(2);
                })
                .catch(error => {
                    console.error('Error fetching details:', error);
                    document.getElementById('modalName').innerText = "Error loading data.";
                });
        }
    </script>
}