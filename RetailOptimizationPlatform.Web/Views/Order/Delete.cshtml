@model RetailOptimizationPlatform.Core.Entities.Order

@{
    ViewData["Title"] = "Delete Order";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-6">
            <div class="card border-danger shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Delete Order</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning mb-3" role="alert">
                        <strong>Warning!</strong> This action cannot be undone. Are you sure you want to delete this order?
                    </div>

                    <h6 class="mb-3">Order Details</h6>
                    <dl class="row">
                        <dt class="col-sm-4">Order ID</dt>
                        <dd class="col-sm-8">@Model.Id</dd>

                        <dt class="col-sm-4">Customer Name</dt>
                        <dd class="col-sm-8">@Model.CustomerName</dd>

                        <dt class="col-sm-4">Ordered Item</dt>
                        <dd class="col-sm-8">
                            @if (Model.Inventory != null && !string.IsNullOrEmpty(Model.Inventory.ItemName))
                            {
                                <span class="badge bg-info">@Model.Inventory.ItemName</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Item No Longer Available</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Order Date</dt>
                        <dd class="col-sm-8">@Model.OrderDate.ToShortDateString()</dd>

                        <dt class="col-sm-4">Total Amount</dt>
                        <dd class="col-sm-8">₹@Model.TotalAmount.ToString("0.00")</dd>
                    </dl>

                    <hr />

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Yes, Delete This Order
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>