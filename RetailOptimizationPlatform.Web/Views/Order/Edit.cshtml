@model RetailOptimizationPlatform.Core.Entities.Order

@{
    ViewData["Title"] = "Edit Order";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Edit Order</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="CustomerName" class="form-label fw-medium">Customer Name <span class="text-danger">*</span></label>
                            <input asp-for="CustomerName" class="form-control" />
                            <div asp-validation-for="CustomerName" class="invalid-feedback d-block"></div>
                            <small class="text-muted">Maximum 100 characters</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="InventoryId" class="form-label fw-medium">Purchased Item <span class="text-danger">*</span></label>
                            <select asp-for="InventoryId" class="form-select" asp-items="@ViewBag.InventoryList"></select>
                            <div asp-validation-for="InventoryId" class="invalid-feedback d-block"></div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="OrderDate" class="form-label fw-medium">Order Date <span class="text-danger">*</span></label>
                                <input asp-for="OrderDate" class="form-control" type="date" />
                                <div asp-validation-for="OrderDate" class="invalid-feedback d-block"></div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="TotalAmount" class="form-label fw-medium">Total Amount (₹) <span class="text-danger">*</span></label>
                                <input asp-for="TotalAmount" class="form-control" type="number" step="0.01" min="0" />
                                <div asp-validation-for="TotalAmount" class="invalid-feedback d-block"></div>
                            </div>
                        </div>

                        <hr />

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Update Order
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}