@model IEnumerable<RetailOptimizationPlatform.Core.Entities.Order>

@{
    ViewData["Title"] = "Order List";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Order Management</h2>
        <a asp-action="Create" class="btn btn-success">Create New Order</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Order ID</th>
                        <th>Customer Name</th>
                        <th>Ordered Item</th>
                        <th>Order Date</th>
                        <th>Total Amount</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.CustomerName</td>
                            <td>
                                @if (item.Inventory != null && !string.IsNullOrEmpty(item.Inventory.ItemName))
                                {
                                    <span class="badge bg-info text-dark">@item.Inventory.ItemName</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Item Deleted</span>
                                }
                            </td>
                            <td>@item.OrderDate.ToShortDateString()</td>
                            <td>₹@item.TotalAmount.ToString("0.00")</td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit Order">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete Order">
                                    <i class="bi bi-trash3"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>