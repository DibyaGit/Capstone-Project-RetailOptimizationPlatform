@{
	ViewData["Title"] = "Performance Dashboard";
}

<div class="container-fluid py-4">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="mb-0">Performance Dashboard</h2>
		<div class="btn-group" role="group">
			<a asp-action="SalesAnalytics" class="btn btn-outline-primary">
				<i class="bi bi-graph-up"></i> Sales
			</a>
			<a asp-action="InventoryAnalytics" class="btn btn-outline-primary">
				<i class="bi bi-box-seam"></i> Inventory
			</a>
			<a asp-action="OrderAnalytics" class="btn btn-outline-primary">
				<i class="bi bi-cart3"></i> Orders
			</a>
			<a asp-action="StoredProcedureRevenueReport" class="btn btn-outline-primary">
				<i class="bi bi-cpu"></i> Database SP Report
			</a>
		</div>
	</div>

	<!-- Executive Summary Row -->
	<div class="row g-3 mb-4">
		<div class="col-12 col-sm-6 col-md-3">
			<div class="card border-0 shadow-sm">
				<div class="card-body">
					<div class="d-flex justify-content-between align-items-start">
						<div>
							<div class="small text-uppercase text-muted">Total Inventory Value</div>
							<div class="h4 fw-bold mt-2">₹@ViewBag.TotalInventoryValue.ToString("0.00")</div>
							<div class="small text-success"><i class="bi bi-arrow-up"></i> Current</div>
						</div>
						<div style="font-size: 32px;">📦</div>
					</div>
				</div>
			</div>
		</div>

		<div class="col-12 col-sm-6 col-md-3">
			<div class="card border-0 shadow-sm">
				<div class="card-body">
					<div class="d-flex justify-content-between align-items-start">
						<div>
							<div class="small text-uppercase text-muted">Total Orders</div>
							<div class="h4 fw-bold mt-2">@ViewBag.TotalOrders</div>
							<div class="small text-muted">All time</div>
						</div>
						<div style="font-size: 32px;">📋</div>
					</div>
				</div>
			</div>
		</div>

		<div class="col-12 col-sm-6 col-md-3">
			<div class="card border-0 shadow-sm">
				<div class="card-body">
					<div class="d-flex justify-content-between align-items-start">
						<div>
							<div class="small text-uppercase text-muted">Avg Order Value</div>
							<div class="h4 fw-bold mt-2">₹@ViewBag.AverageOrderValue.ToString("0.00")</div>
							<div class="small text-muted">Per order</div>
						</div>
						<div style="font-size: 32px;">💰</div>
					</div>
				</div>
			</div>
		</div>

		<div class="col-12 col-sm-6 col-md-3">
			<div class="card border-0 shadow-sm">
				<div class="card-body">
					<div class="d-flex justify-content-between align-items-start">
						<div>
							<div class="small text-uppercase text-muted">Low Stock Items</div>
							<div class="h4 fw-bold mt-2" style="color: #ef4444;">@ViewBag.LowStockItems</div>
							<div class="small text-danger">Action needed</div>
						</div>
						<div style="font-size: 32px;">⚠️</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- KPI Performance Cards -->
	<div class="row g-3">
		<div class="col-12 col-lg-6">
			<div class="card border-0 shadow-sm">
				<div class="card-header bg-light border-bottom">
					<h5 class="mb-0">Health Check</h5>
				</div>
				<div class="card-body">
					<div class="list-group list-group-flush">
						<div class="list-group-item d-flex justify-content-between align-items-center">
							<div>
								<h6 class="mb-1">Inventory Level</h6>
								<small class="text-muted">Stock monitoring</small>
							</div>
							<span class="badge bg-success">Healthy</span>
						</div>
						<div class="list-group-item d-flex justify-content-between align-items-center">
							<div>
								<h6 class="mb-1">Order Processing</h6>
								<small class="text-muted">Order throughput</small>
							</div>
							<span class="badge bg-success">On Track</span>
						</div>
						<div class="list-group-item d-flex justify-content-between align-items-center">
							<div>
								<h6 class="mb-1">Revenue Trend</h6>
								<small class="text-muted">Sales performance</small>
							</div>
							<span class="badge bg-success">Growing</span>
						</div>
						<div class="list-group-item d-flex justify-content-between align-items-center">
							<div>
								<h6 class="mb-1">Customer Satisfaction</h6>
								<small class="text-muted">Quality metrics</small>
							</div>
							<span class="badge bg-success">Excellent</span>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="col-12 col-lg-6">
			<div class="card border-0 shadow-sm">
				<div class="card-header bg-light border-bottom">
					<h5 class="mb-0">Business Metrics</h5>
				</div>
				<div class="card-body">
					<div class="mb-4">
						<div class="d-flex justify-content-between mb-2">
							<span class="fw-medium">Inventory Turnover Ratio</span>
							<strong>@ViewBag.TurnoverRatio.ToString("0.00")x</strong>
						</div>
						<div class="progress" style="height: 8px;">
							<div class="progress-bar bg-info" style="width: 65%"></div>
						</div>
						<small class="text-muted">Monthly turnover rate</small>
					</div>

					<div class="mb-4">
						<div class="d-flex justify-content-between mb-2">
							<span class="fw-medium">Order Fulfillment Rate</span>
							<strong>98.5%</strong>
						</div>
						<div class="progress" style="height: 8px;">
							<div class="progress-bar bg-success" style="width: 98.5%"></div>
						</div>
						<small class="text-muted">Successfully processed orders</small>
					</div>

					<div class="mb-4">
						<div class="d-flex justify-content-between mb-2">
							<span class="fw-medium">Stock Availability</span>
							<strong>94.2%</strong>
						</div>
						<div class="progress" style="height: 8px;">
							<div class="progress-bar bg-success" style="width: 94.2%"></div>
						</div>
						<small class="text-muted">Items in stock</small>
					</div>

					<div>
						<div class="d-flex justify-content-between mb-2">
							<span class="fw-medium">System Health</span>
							<strong>100%</strong>
						</div>
						<div class="progress" style="height: 8px;">
							<div class="progress-bar bg-success" style="width: 100%"></div>
						</div>
						<small class="text-muted">All systems operational</small>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
